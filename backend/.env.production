# 生产环境配置 — 部署前务必修改所有 CHANGE_ME 占位值

# 服务端口
PORT=3000

# 数据库配置
DB_HOST=mysql
DB_USER=negentropy_prod
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
DB_NAME=negentropy_production
DB_CONNECTION_LIMIT=50

# Redis 配置
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# JWT安全密钥（请使用 openssl rand -hex 64 生成）
JWT_SECRET=CHANGE_ME_JWT_SECRET

# 跨域配置
CORS_ORIGIN=https://your-production-domain.com
CORS_CREDENTIALS=true

# 日志配置
LOG_LEVEL=info
LOG_PATH=/var/log/negentropy/app.log
ERROR_LOG_PATH=/var/log/negentropy/error.log
ACCESS_LOG_PATH=/var/log/negentropy/access.log

# 会话密钥
SESSION_SECRET=CHANGE_ME_SESSION_SECRET

# 环境标识
NODE_ENV=production

# 安全配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
BCRYPT_ROUNDS=12

# 备份配置
BACKUP_PATH=/var/backups/negentropy

# AI 审核配置（DeepSeek API）
AI_AUDIT_ENABLED=true
AI_AUDIT_PROVIDER=deepseek
AI_AUDIT_API_KEY=CHANGE_ME_AI_API_KEY
AI_AUDIT_BASE_URL=https://api.deepseek.com
AI_AUDIT_MODEL=deepseek-chat
AI_AUDIT_TIMEOUT_MS=8000
AI_AUDIT_MAX_RETRIES=2
