{
  "name": "negentropy-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "test": "node --test src/__tests__/*.test.js src/__tests__/*.test.mjs",
    "migrate": "node scripts/migrate.js",
    "migrate:dry": "node scripts/migrate.js --dry-run",
    "lint": "eslint \"src\" --ext .js --max-warnings 100",
    "lint:fix": "eslint \"src\" --ext .js --fix",
    "format": "prettier --write \"src/**/*.js\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "express-rate-limit": "^8.5.1",
    "express-validator": "^7.0.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.0",
    "mysql2": "^3.9.0",
    "openai": "^6.37.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.2.0"
  }
}
