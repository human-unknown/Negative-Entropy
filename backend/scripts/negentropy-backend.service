[Unit]
Description=Negentropy Backend Service
After=network.target mysql.service

[Service]
Type=simple
User=www-data
WorkingDirectory=/app/backend
ExecStart=/usr/bin/node server.js
Restart=always
RestartSec=10
StandardOutput=append:/var/log/negentropy/app.log
StandardError=append:/var/log/negentropy/error.log

[Install]
WantedBy=multi-user.target
